generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Plan values: "FREE" | "PRO" | "ENTERPRISE"
// Role values: "USER" | "ADMIN"
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  passwordHash String?
  githubId     String?  @unique
  avatarUrl    String?
  plan         String   @default("FREE")
  role         String   @default("USER")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile         Profile?
  projects        Project[]
  subscription    Subscription?
  teamMemberships TeamMember[]
  ownedTeams      Team[]
}

model Profile {
  id             String   @id @default(cuid())
  userId         String   @unique
  githubUsername String?
  linkedinUrl    String?
  bio            String?
  skills         String   @default("[]")
  yearsOfExp     Int      @default(0)
  currentRole    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetRoles TargetRole[]
  skillGaps   SkillGap[]
}

model TargetRole {
  id           String   @id @default(cuid())
  profileId    String
  company      String
  title        String
  level        String
  requirements String   @default("[]")
  matchScore   Int      @default(0)
  summary      String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile   Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)
  skillGaps SkillGap[]
}

// priority: "HIGH" | "MEDIUM" | "LOW"
// status: "OPEN" | "IN_PROGRESS" | "CLOSED"
model SkillGap {
  id            String   @id @default(cuid())
  profileId     String
  targetRoleId  String
  title         String
  description   String?
  priority      String   @default("MEDIUM")
  estimatedDays Int      @default(3)
  status        String   @default("OPEN")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  profile    Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)
  targetRole TargetRole @relation(fields: [targetRoleId], references: [id], onDelete: Cascade)
  project    Project?
}

// status: "PENDING" | "IN_PROGRESS" | "COMPLETED" | "ABANDONED"
// difficulty: "EASY" | "MEDIUM" | "HARD"
model Project {
  id          String    @id @default(cuid())
  userId      String
  skillGapId  String?   @unique
  title       String
  description String
  techStack   String    @default("[]")
  difficulty  String    @default("MEDIUM")
  status      String    @default("PENDING")
  progress    Int       @default(0)
  githubUrl   String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillGap SkillGap? @relation(fields: [skillGapId], references: [id])
}

// plan: "FREE" | "PRO" | "ENTERPRISE"
// status: "ACTIVE" | "CANCELED" | "PAST_DUE"
model Subscription {
  id                 String   @id @default(cuid())
  userId             String   @unique
  plan               String   @default("FREE")
  status             String   @default("ACTIVE")
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Team {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  ownerId   String
  plan      String   @default("FREE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner   User         @relation(fields: [ownerId], references: [id])
  members TeamMember[]
}

// teamRole: "OWNER" | "ADMIN" | "MEMBER"
model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  userId   String
  teamRole String   @default("MEMBER")
  joinedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}
