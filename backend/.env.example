DATABASE_URL="file:./dev.db"
JWT_SECRET="genera-un-secreto-fuerte-aqui-nunca-uses-este-valor"
JWT_EXPIRES_IN="7d"
PORT=3001
FRONTEND_URL="http://localhost:5173"

# GitHub OAuth App (crear en github.com/settings/developers)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# GitHub Personal Access Token (para analizar repos de usuarios)
# Crear en github.com/settings/tokens con permisos: repo, read:user
GITHUB_TOKEN=""

# Groq API Key (para análisis con IA Llama, usado en /api/analysis/analyze)
# Crear en console.groq.com/keys. Si se deja vacío, el análisis cae a un
# cálculo determinístico de respaldo en vez de fallar.
GROQ_API_KEY=""
